# Canonical site URL for OG images and metadata (must match custom domain)
NEXT_PUBLIC_SITE_URL=https://basemate.app

# Production agent API (required on Railway — same project as xmtp-agent)
AGENT_API_HOST=https://xmtp-agent-production-e08b.up.railway.app

# Optional override for /portfolio proxy. Defaults to AGENT_API_HOST when unset.
# Local dev (basemate-tba on :3000, metrics on :3001):
#   AGENT_API_HOST=http://localhost:3000
IMESSAGE_PORTFOLIO_API_HOST=

# Postgres — used for waitlist entries and /pay fund_sessions.
# /pay must use the same DB as basemate-imessage so it can redeem Coinbase payment-link sessions.
DATABASE_URL=postgresql://neondb_owner:npg_ToFSgqIMRh73@ep-calm-salad-ate70nd3-pooler.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Coinbase Headless Onramp sandbox:
# Set basemate-imessage CDP_FUND_PAGE_URL=http://localhost:3001/pay
# and CDP_FUND_PAGE_DOMAIN=localhost when testing this app locally.

# Bankr lifetime volume — metrics app reads Dune GET (no execute, no credits per poll).
# Use the dashboard query: https://dune.com/freeksh00w/basemate
DUNE_API_KEY=
DUNE_BANKR_LIFETIME_QUERY_ID=7729265

# Base MCP OAuth callback (/api/mcp/callback). Exchanges the authorization code
# for tokens and writes them encrypted to the shared `base_mcp_oauth` table that
# basemate-imessage reads. Values must match the iMessage service exactly.
BASE_MCP_SERVER_URL=https://mcp.base.org
BASE_MCP_CLIENT_ID=
BASE_MCP_REDIRECT_URI=https://basemate.app/api/mcp/callback
BASE_MCP_SCOPE=agent_wallet:transact
# AES-256-GCM secret used to encrypt OAuth tokens — MUST equal the iMessage value.
BASE_MCP_OAUTH_ENC_KEY=
