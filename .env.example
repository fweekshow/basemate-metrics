# Canonical site URL for OG images and metadata (must match custom domain)
NEXT_PUBLIC_SITE_URL=https://basemate.app

# Production agent API (required on Railway — same project as xmtp-agent)
AGENT_API_HOST=https://xmtp-agent-production-e08b.up.railway.app

# Optional override for /portfolio proxy. Defaults to AGENT_API_HOST when unset.
# Local dev (basemate-tba on :3000, metrics on :3001):
#   AGENT_API_HOST=http://localhost:3000
IMESSAGE_PORTFOLIO_API_HOST=

# Dune Analytics API key (for lifetime token volume queries)
DUNE_API_KEY=
